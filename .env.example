# ──────────────────────────────────────────────
# CLÉS API (à remplir avec vos propres valeurs)
# ──────────────────────────────────────────────

# OpenAI — votre clé API (commence par sk-)
OPENAI_API_KEY=sk-xxxx-xxxx-xxxx

# OpenAI — modèle à utiliser (ne pas changer sauf raison précise)
OPENAI_MODEL=gpt-4o

# ScraperAPI — votre clé API (visible sur scraperapi.com/dashboard)
SCRAPER_API_KEY=XXXXXXXXXXXXXXXXXXXXXXX

# ──────────────────────────────────────────────
# INFRASTRUCTURE (rempli automatiquement par Railway)
# ──────────────────────────────────────────────

# Redis — URL de connexion (fournie par Railway quand vous ajoutez Redis)
REDIS_URL=redis://localhost:6379/0

# Base de données — chemin du fichier SQLite
DB_PATH=benchmarks.db

# ──────────────────────────────────────────────
# FRONTEND
# ──────────────────────────────────────────────

# URL du backend API (sera l'URL Railway de votre service backend)
NEXT_PUBLIC_API_URL=http://localhost:8000
